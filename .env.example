# Copy to `.env` and adjust if needed.
# Matches credentials in docker-compose.yml — works out of the box with `pnpm db:up`.
DATABASE_URL="postgresql://koleso:koleso@localhost:5432/koleso?schema=public"

# Cloudflare R2 (photo storage).
# Account ID + bucket: visible in Cloudflare dashboard.
# Public URL: R2 bucket → Settings → Public Development URL (or your custom domain).
# Access keys: R2 → Manage R2 API Tokens → Create Token (Object Read & Write, scoped to bucket).
R2_ACCOUNT_ID=""
R2_BUCKET=""
R2_PUBLIC_URL=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Clerk (auth). Pull from https://dashboard.clerk.com.
# Sign-in/sign-up paths and fallback redirects.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Webhook signing secret. Get it after creating the webhook endpoint
# in Clerk dashboard (Webhooks → Add Endpoint).
CLERK_WEBHOOK_SIGNING_SECRET=""
